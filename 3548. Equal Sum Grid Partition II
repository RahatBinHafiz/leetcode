#include <vector>
#include <unordered_map>
#include <cmath>
#include <algorithm>

using namespace std;

class Solution {
public:
    bool canPartitionGrid(vector<vector<int>>& grid) {
        int m = grid.size();
        int n = grid[0].size();
        
        vector<long long> row_sum(m, 0);
        vector<long long> col_sum(n, 0);
        
        unordered_map<long long, int> min_row, max_row, min_col, max_col;
        long long total = 0;
        
        for (int r = 0; r < m; ++r) {
            for (int c = 0; c < n; ++c) {
                long long val = grid[r][c];
                row_sum[r] += val;
                col_sum[c] += val;
                total += val;
                
                if (!min_row.count(val)) min_row[val] = r;
                min_row[val] = min(min_row[val], r);
                max_row[val] = max(max_row[val], r);
                
                if (!min_col.count(val)) min_col[val] = c;
                min_col[val] = min(min_col[val], c);
                max_col[val] = max(max_col[val], c);
            }
        }
        
        vector<long long> pref_row(m, 0);
        pref_row[0] = row_sum[0];
        for (int r = 1; r < m; ++r) pref_row[r] = pref_row[r-1] + row_sum[r];
        
        vector<long long> pref_col(n, 0);
        pref_col[0] = col_sum[0];
        for (int c = 1; c < n; ++c) pref_col[c] = pref_col[c-1] + col_sum[c];
        
        for (int i = 0; i < m - 1; ++i) {
            long long topSum = pref_row[i];
            long long botSum = total - topSum;
            long long diff = abs(topSum - botSum);
            
            if (diff == 0) return true;
            
            if (topSum > botSum) {
                bool canRemove = false;
                if (i == 0 || n == 1) {
                    if (grid[0][0] == diff || grid[0][n-1] == diff || 
                        grid[i][0] == diff || grid[i][n-1] == diff) canRemove = true;
                } else {
                    if (min_row.count(diff) && min_row[diff] <= i) canRemove = true;
                }
                if (canRemove) return true;
                
            } else {
                bool canRemove = false;
                if (i == m - 2 || n == 1) {
                    if (grid[i+1][0] == diff || grid[i+1][n-1] == diff || 
                        grid[m-1][0] == diff || grid[m-1][n-1] == diff) canRemove = true;
                } else {
                    if (max_row.count(diff) && max_row[diff] > i) canRemove = true;
                }
                if (canRemove) return true;
            }
        }
        
        for (int j = 0; j < n - 1; ++j) {
            long long leftSum = pref_col[j];
            long long rightSum = total - leftSum;
            long long diff = abs(leftSum - rightSum);
            
            if (diff == 0) return true;
            
            if (leftSum > rightSum) {
                bool canRemove = false;
                if (j == 0 || m == 1) {
                    if (grid[0][0] == diff || grid[m-1][0] == diff || 
                        grid[0][j] == diff || grid[m-1][j] == diff) canRemove = true;
                } else {
                    if (min_col.count(diff) && min_col[diff] <= j) canRemove = true;
                }
                if (canRemove) return true;
                
            } else {
                bool canRemove = false;
                if (j == n - 2 || m == 1) {
                    if (grid[0][j+1] == diff || grid[m-1][j+1] == diff || 
                        grid[0][n-1] == diff || grid[m-1][n-1] == diff) canRemove = true;
                } else {
                    if (max_col.count(diff) && max_col[diff] > j) canRemove = true;
                }
                if (canRemove) return true;
            }
        }
        
        return false;
    }
};
