class Solution {
public:
    int minOperations(string s) {
        int ans1 = 0, ans2 =0; int n = s.size();
        string s1= "", s2="";
        for(int i = 0 ; i<n ; i++) {
            if(i&1) s1 +='0'; else s1 += '1';
        }
          for(int i = 0 ; i<n ; i++) {
            if(i&1) s2 +='1'; else s2 +='0';
        }
        for(int i = 0; i<n; i++)
        {
            if(s[i] != s1[i])
            {
                 ans1++;
            }
            if(s[i] != s2[i])
            {
                 ans2++;
            }
        }

        return min(ans1, ans2);
    }
};
