class Solution {
public:
    vector<vector<int>> adj;
    vector<bool> vis;
    vector<int> comp;

    void dfs(int u) {
        vis[u] = true;
        comp.push_back(u);
        for (int v : adj[u]) {
            if (!vis[v]) dfs(v);
        }
    }

    int countCompleteComponents(int n, vector<vector<int>>& edges) {
        adj.assign(n, {});
        vis.assign(n, false);

        for (auto &e : edges) {
            adj[e[0]].push_back(e[1]);
            adj[e[1]].push_back(e[0]);
        }

        int ans = 0;

        for (int i = 0; i < n; i++) {
            if (!vis[i]) {
                comp.clear();
                dfs(i);

                int sz = comp.size();
                bool ok = true;

                for (int u : comp) {
                    if (adj[u].size() != sz - 1) {
                        ok = false;
                        break;
                    }
                }

                if (ok) ans++;
            }
        }

        return ans;
    }
};
