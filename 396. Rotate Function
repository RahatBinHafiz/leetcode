class Solution {
public:
    #define ll long long int
    int maxRotateFunction(vector<int>& nums) {
        ll n = nums.size();
        ll numsum = accumulate(nums.begin(), nums.end(),0);
        ll x = 0; 
        for(int i = 0; i<n; i++)
        {
            x+=i*nums[i];
        }
        ll ans = x; 
        for(int i = n-1; i>=0; i--)
        {
            x+=( numsum - n*nums[i]); 
            ans = max (ans, x);
        }
       
       return ans;
    }
};
